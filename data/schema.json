{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sbphsho1030.github.io/m7-dashboard/data/schema.json",
  "title": "M7 Dashboard Data Schema v1.2",
  "description": "Schema documentation for latest.json, recent.json, history-index.json, monthly history files, and legacy history.json.",
  "type": "object",
  "definitions": {
    "date": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
    "month": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}$" },
    "light": { "type": "string", "enum": ["green", "yellow", "red", "blue", "purple"] },
    "sourceReports": {
      "type": "object",
      "required": ["dashboard", "fullReport", "archive"],
      "properties": {
        "dashboard": { "type": "string" },
        "fullReport": { "type": "string" },
        "archive": { "type": "string" }
      },
      "additionalProperties": true
    },
    "rankingItem": {
      "type": "object",
      "required": ["rank", "ticker", "company", "rating", "score", "scoreBand", "scoreReason", "newCapitalStance", "riskLight", "triggerStatus"],
      "properties": {
        "rank": { "type": "integer", "minimum": 1, "maximum": 7 },
        "ticker": { "type": "string", "enum": ["AAPL", "MSFT", "GOOGL", "AMZN", "NVDA", "META", "TSLA"] },
        "company": { "type": "string" },
        "rating": { "type": "string" },
        "score": { "type": "number", "minimum": 0, "maximum": 100 },
        "scoreBand": { "type": "string" },
        "scoreReason": { "type": "string" },
        "scoreBreakdown": { "type": ["object", "null"] },
        "newCapitalStance": { "type": "string" },
        "riskLight": { "$ref": "#/definitions/light" },
        "triggerStatus": { "type": "string" },
        "weeklyDelta": { "type": ["number", "string", "null"] },
        "monthlyDelta": { "type": ["number", "string", "null"] },
        "rankChangeWeek": { "type": ["number", "null"] },
        "rankChangeMonth": { "type": ["number", "null"] },
        "redStreakDays": { "type": ["integer", "null"], "minimum": 0 },
        "deltaNote": { "type": "string" }
      },
      "additionalProperties": true
    },
    "dailyRecord": {
      "type": "object",
      "required": ["date", "reportId", "sourceReports", "headline", "oneLineConclusion", "recommendedAction", "marketRegime", "m7Ranking", "triggerRules", "dataQuality"],
      "properties": {
        "date": { "$ref": "#/definitions/date" },
        "reportId": { "type": "string" },
        "sourceReports": { "$ref": "#/definitions/sourceReports" },
        "headline": { "type": "string" },
        "oneLineConclusion": { "type": "string" },
        "recommendedAction": { "type": "string" },
        "m7Ranking": { "type": "array", "minItems": 7, "maxItems": 7, "items": { "$ref": "#/definitions/rankingItem" } }
      },
      "additionalProperties": true
    }
  },
  "oneOf": [
    {
      "title": "latest.json",
      "type": "object",
      "required": ["schemaVersion", "project", "updatedAt", "latestDate", "latestReportId", "sourceReports", "summary", "riskLights", "ranking", "triggerRules", "dataQuality"],
      "properties": {
        "project": { "const": "m7-dashboard" },
        "latestDate": { "$ref": "#/definitions/date" },
        "sourceReports": { "$ref": "#/definitions/sourceReports" },
        "ranking": { "type": "array", "minItems": 7, "maxItems": 7, "items": { "$ref": "#/definitions/rankingItem" } }
      },
      "additionalProperties": true
    },
    {
      "title": "recent.json or monthly history file or legacy history.json",
      "type": "object",
      "required": ["schemaVersion", "project", "updatedAt", "records"],
      "properties": {
        "project": { "const": "m7-dashboard" },
        "month": { "$ref": "#/definitions/month" },
        "records": { "type": "array", "items": { "$ref": "#/definitions/dailyRecord" } }
      },
      "additionalProperties": true
    },
    {
      "title": "history-index.json",
      "type": "object",
      "required": ["schemaVersion", "project", "updatedAt", "records"],
      "properties": {
        "project": { "const": "m7-dashboard" },
        "records": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["date", "reportId", "headline", "monthFile"],
            "properties": {
              "date": { "$ref": "#/definitions/date" },
              "reportId": { "type": "string" },
              "headline": { "type": "string" },
              "recommendedAction": { "type": "string" },
              "topTicker": { "type": "string" },
              "topScore": { "type": ["number", "null"] },
              "maxRedStreak": { "type": "integer", "minimum": 0 },
              "monthFile": { "type": "string" },
              "fullReport": { "type": "string" }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    }
  ]
}
