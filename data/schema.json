{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sbphsho1030.github.io/m7-dashboard/data/schema.json",
  "title": "M7 Dashboard Data Schema",
  "description": "Schema documentation for latest.json and history.json used by the M7 Decision Control Dashboard.",
  "type": "object",
  "definitions": {
    "date": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "light": {
      "type": "string",
      "enum": ["green", "yellow", "red", "blue", "purple"]
    },
    "sourceReports": {
      "type": "object",
      "required": ["dashboard", "fullReport", "archive"],
      "properties": {
        "dashboard": { "type": "string" },
        "fullReport": { "type": "string" },
        "archive": { "type": "string" }
      },
      "additionalProperties": true
    },
    "latestRankingItem": {
      "type": "object",
      "required": ["rank", "ticker", "company", "rating", "newCapitalStance", "riskLight", "triggerStatus"],
      "properties": {
        "rank": { "type": "integer", "minimum": 1, "maximum": 7 },
        "ticker": { "type": "string", "enum": ["AAPL", "MSFT", "GOOGL", "AMZN", "NVDA", "META", "TSLA"] },
        "company": { "type": "string" },
        "rating": { "type": "string" },
        "newCapitalStance": { "type": "string" },
        "riskLight": { "$ref": "#/definitions/light" },
        "triggerStatus": { "type": "string" },
        "weeklyDelta": { "type": ["number", "string", "null"] },
        "monthlyDelta": { "type": ["number", "string", "null"] },
        "deltaNote": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "oneOf": [
    {
      "title": "latest.json",
      "type": "object",
      "required": ["schemaVersion", "project", "updatedAt", "latestDate", "latestReportId", "sourceReports", "summary", "riskLights", "ranking", "triggerRules", "dataQuality"],
      "properties": {
        "schemaVersion": { "type": "string" },
        "project": { "const": "m7-dashboard" },
        "updatedAt": { "type": "string" },
        "latestDate": { "$ref": "#/definitions/date" },
        "latestReportId": { "type": "string" },
        "sourceReports": { "$ref": "#/definitions/sourceReports" },
        "summary": {
          "type": "object",
          "required": ["headline", "oneLineConclusion", "recommendedAction", "directionality", "killSwitchTriggered", "nextActionMode"]
        },
        "riskLights": { "type": "object" },
        "ranking": {
          "type": "array",
          "minItems": 7,
          "maxItems": 7,
          "items": { "$ref": "#/definitions/latestRankingItem" }
        },
        "triggerRules": { "type": "object" },
        "dataQuality": { "type": "object" }
      },
      "additionalProperties": true
    },
    {
      "title": "history.json",
      "type": "object",
      "required": ["schemaVersion", "project", "updatedAt", "records"],
      "properties": {
        "schemaVersion": { "type": "string" },
        "project": { "const": "m7-dashboard" },
        "updatedAt": { "type": "string" },
        "records": {
          "type": "array",
          "items": { "type": "object" }
        }
      },
      "additionalProperties": true
    }
  ]
}
